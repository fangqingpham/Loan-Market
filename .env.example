# ─────────────────────────────────────────────────────────────
# Loan Market — Environment Variables
# Copy this file to ".env.local" and fill in real values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe to expose to the browser.
# (Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service role key — SERVER ONLY. Never expose to the client.
# Used later for admin tasks (e.g. manual lender verification).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for redirects/links). Local default below.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional alias also read by the app for building absolute URLs (Checkout
# success/cancel). If unset, NEXT_PUBLIC_SITE_URL (or localhost) is used.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Stripe (Payments) — fill in before launch. While these are blank, the app
# runs normally but the borrower "Pay to open messaging" step shows a
# "payments not set up yet" message instead of starting checkout.
# ─────────────────────────────────────────────────────────────

# Secret key — SERVER ONLY. Test mode starts with sk_test_...
# (Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Publishable key — safe for the browser. Test mode starts with pk_test_...
# (Not strictly required for Checkout redirects, included for completeness.)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Webhook signing secret — SERVER ONLY. Starts with whsec_...
# Get it from `stripe listen` (CLI) for local testing, or from the Dashboard
# webhook endpoint you create pointing at /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
